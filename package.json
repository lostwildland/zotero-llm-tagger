{
  "name": "zotero-ai-tagger",
  "type": "module",
  "version": "0.1.0",
  "description": "AI-assisted tag suggestion plugin for Zotero with OpenAI, Azure OpenAI, and compatible providers",
  "config": {
    "addonName": "AI Tagger",
    "addonID": "ai-tagger@zotero.dev",
    "addonRef": "aitagger",
    "addonInstance": "AITagger",
    "prefsPrefix": "extensions.zotero.aitagger"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lostwildland/zotero-llm-tagger.git"
  },
  "author": "Lost Wildland",
  "bugs": {
    "url": "https://github.com/lostwildland/zotero-llm-tagger/issues"
  },
  "homepage": "https://github.com/lostwildland/zotero-llm-tagger#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "build:xpi": "npm run build && mkdir -p build && cp .scaffold/build/*.xpi build/",
    "lint:check": "prettier --check . && eslint . --ignore-pattern \"AI Tag Suggester for Zotero.js\"",
    "lint:fix": "prettier --write . && eslint . --fix --ignore-pattern \"AI Tag Suggester for Zotero.js\"",
    "release": "zotero-plugin release",
    "test": "npm run test:unit",
    "test:unit": "mocha --require jiti/register \"test/responseParser.test.ts\" \"test/tagList.test.ts\" \"test/workflow.test.ts\"",
    "test:zotero": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "jiti": "^2.7.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
